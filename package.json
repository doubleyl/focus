    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "electron": "^35.0.0",
        "electron-builder": "^25.0.0",
        "framer-motion": "^12.0.0",
        "lucide-react": "^0.475.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "recharts": "^2.15.0",
        "typescript": "^5.7.0",
        "vite": "^6.2.0",
        "vite-plugin-electron": "^0.28.0",
